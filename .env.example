# Database (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/dotco?schema=public"

# NextAuth
AUTH_SECRET="generate-with: openssl rand -base64 32"
AUTH_URL="http://localhost:3001"

# App URL (used in emails and calendar invites)
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# File uploads
UPLOAD_DIR="./uploads"

# Deepgram (audio transcription with speaker diarization)
# Get your key at https://console.deepgram.com
DEEPGRAM_API_KEY=""

# OpenAI (meeting summarization with GPT-4o)
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# Resend (email notifications and calendar invites)
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Dotco <noreply@yourdomain.com>"

# Storage backend (one of these three; checked in order)
# 1. Vercel Blob
BLOBPRO_READ_WRITE_TOKEN=""

# 2. S3 / S3-compatible (e.g. MinIO, Cloudflare R2)
S3_BUCKET=""
S3_REGION="us-east-1"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_ENDPOINT=""          # optional — set for S3-compatible services

# 3. Local filesystem (fallback)
# UPLOAD_DIR is already set above
